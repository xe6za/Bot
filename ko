<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jam WIB Jakarta</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #060a0f;
    --panel: #0c1219;
    --border: #1a2a3a;
    --green: #00ff88;
    --green-dim: #00aa55;
    --green-glow: rgba(0,255,136,0.15);
    --amber: #ffaa00;
    --amber-dim: #cc7700;
    --amber-glow: rgba(255,170,0,0.15);
    --red: #ff3355;
    --cyan: #00ddff;
    --text: #8ab4cc;
    --text-dim: #3a5566;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow: hidden;
  }

  /* Scanline overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 999;
  }

  /* Grid background */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,255,136,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,136,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Header */
  .header {
    text-align: center;
    letter-spacing: 0.3em;
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--border);
  }
  .header span { color: var(--green); }

  /* Main clock panel */
  .clock-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 32px 24px 24px;
    position: relative;
    box-shadow: 0 0 40px rgba(0,255,136,0.04), inset 0 1px 0 rgba(255,255,255,0.04);
  }
  .clock-panel::before {
    content: 'WIB / UTC+7 / JAKARTA';
    position: absolute;
    top: -1px; left: 20px;
    background: var(--panel);
    color: var(--green-dim);
    font-size: 9px;
    letter-spacing: 0.2em;
    padding: 0 8px;
    border-top: 1px solid var(--green-dim);
  }

  .time-display {
    font-family: 'Orbitron', monospace;
    font-size: clamp(52px, 14vw, 96px);
    font-weight: 900;
    color: var(--green);
    text-align: center;
    letter-spacing: 0.05em;
    text-shadow: 0 0 20px rgba(0,255,136,0.5), 0 0 60px rgba(0,255,136,0.2);
    line-height: 1;
    transition: text-shadow 0.1s;
  }
  .time-display .colon {
    animation: blink 1s step-end infinite;
    display: inline-block;
    width: 0.3em;
    text-align: center;
  }
  @keyframes blink { 50% { opacity: 0.1; } }

  .date-display {
    text-align: center;
    margin-top: 12px;
    font-size: 13px;
    color: var(--text-dim);
    letter-spacing: 0.15em;
  }
  .date-display .day-name { color: var(--text); }

  /* Progress bar — next trigger */
  .next-section {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .next-label {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .next-label .countdown-next { color: var(--amber); font-weight: bold; }

  .progress-bar {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--amber-dim), var(--amber));
    border-radius: 2px;
    transition: width 0.5s linear;
    box-shadow: 0 0 8px var(--amber-dim);
  }

  /* Stopwatch panel */
  .sw-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px;
    position: relative;
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .sw-panel.active {
    border-color: var(--amber);
    box-shadow: 0 0 30px rgba(255,170,0,0.1), inset 0 0 20px rgba(255,170,0,0.03);
  }
  .sw-panel.idle {
    border-color: var(--border);
  }

  .sw-panel::before {
    content: 'STOPWATCH';
    position: absolute;
    top: -1px; left: 20px;
    background: var(--panel);
    font-size: 9px;
    letter-spacing: 0.2em;
    padding: 0 8px;
    border-top: 1px solid;
    transition: color 0.3s, border-color 0.3s;
  }
  .sw-panel.active::before { color: var(--amber); border-color: var(--amber); }
  .sw-panel.idle::before   { color: var(--text-dim); border-color: var(--text-dim); }

  .sw-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .sw-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--text-dim);
    transition: background 0.3s, box-shadow 0.3s;
  }
  .sw-panel.active .sw-dot {
    background: var(--amber);
    box-shadow: 0 0 8px var(--amber);
    animation: pulse 1s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.7; }
  }
  .sw-status-text { color: var(--text-dim); }
  .sw-panel.active .sw-status-text { color: var(--amber); }

  .sw-time {
    font-family: 'Orbitron', monospace;
    font-size: clamp(36px, 9vw, 64px);
    font-weight: 700;
    color: var(--text-dim);
    text-align: center;
    letter-spacing: 0.08em;
    transition: color 0.3s, text-shadow 0.3s;
  }
  .sw-panel.active .sw-time {
    color: var(--amber);
    text-shadow: 0 0 20px rgba(255,170,0,0.5);
  }

  /* Stopwatch progress */
  .sw-progress {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .sw-progress-label {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .sw-progress-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .sw-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--amber-dim), var(--amber));
    border-radius: 2px;
    transition: width 0.5s linear, background 0.3s;
    box-shadow: 0 0 6px var(--amber-dim);
    width: 0%;
  }
  .sw-panel.idle .sw-progress-fill {
    background: var(--border);
    box-shadow: none;
  }

  /* Session log */
  .log-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px;
    position: relative;
    max-height: 130px;
    overflow: hidden;
  }
  .log-panel::before {
    content: 'SESSION LOG';
    position: absolute;
    top: -1px; left: 20px;
    background: var(--panel);
    color: var(--text-dim);
    font-size: 9px;
    letter-spacing: 0.2em;
    padding: 0 8px;
    border-top: 1px solid var(--text-dim);
  }
  .log-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 11px;
    margin-top: 4px;
  }
  .log-item {
    display: flex;
    gap: 12px;
    color: var(--text-dim);
    line-height: 1.5;
    animation: fadeIn 0.4s ease;
  }
  .log-item.start .log-event { color: var(--amber); }
  .log-item.stop  .log-event { color: var(--green); }
  .log-time { color: var(--text-dim); min-width: 72px; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(-4px); } }

  .log-empty { font-size: 11px; color: var(--text-dim); margin-top: 4px; letter-spacing: 0.1em; }

  /* Footer */
  .footer {
    text-align: center;
    font-size: 9px;
    color: var(--text-dim);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
</style>
</head>
<body>
<div class="wrapper">

  <div class="header">
    SISTEM WAKTU <span>REALTIME</span> · ZONA WAKTU INDONESIA BARAT
  </div>

  <!-- Clock -->
  <div class="clock-panel">
    <div class="time-display" id="clockDisplay">
      <span id="hh">00</span><span class="colon">:</span><span id="mm">00</span><span class="colon">:</span><span id="ss">00</span>
    </div>
    <div class="date-display">
      <span class="day-name" id="dayName">–</span>&nbsp;·&nbsp;<span id="dateStr">– – –</span>
    </div>

    <div class="next-section">
      <div class="next-label">
        <span>stopwatch berikutnya</span>
        <span class="countdown-next" id="nextCountdown">–:––</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="nextProgress" style="width:0%"></div>
      </div>
    </div>
  </div>

  <!-- Stopwatch -->
  <div class="sw-panel idle" id="swPanel">
    <div class="sw-status">
      <div class="sw-dot" id="swDot"></div>
      <span class="sw-status-text" id="swStatusText">STANDBY</span>
    </div>
    <div class="sw-time" id="swDisplay">00:00</div>
    <div class="sw-progress">
      <div class="sw-progress-label">
        <span>durasi aktif</span>
        <span id="swDurLabel">0 / 30 menit</span>
      </div>
      <div class="sw-progress-bar">
        <div class="sw-progress-fill" id="swProgressFill"></div>
      </div>
    </div>
  </div>

  <!-- Log -->
  <div class="log-panel">
    <ul class="log-list" id="logList">
      <li class="log-empty" id="logEmpty">· belum ada sesi tercatat</li>
    </ul>
  </div>

  <div class="footer">AUTO STOPWATCH · AKTIF 30 MIN · ISTIRAHAT 30 MIN</div>

</div>

<script>
  const SW_DURATION = 30 * 60; // 30 menit dalam detik
  const CYCLE = 60 * 60;       // total siklus 60 menit

  const DAYS_ID = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
  const MONTHS_ID = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];

  let swRunning = false;
  let swElapsed = 0; // detik, berapa lama stopwatch sudah jalan di sesi ini
  let logs = [];

  function pad(n) { return String(n).padStart(2,'0'); }

  function getWIBNow() {
    // WIB = UTC+7
    const now = new Date();
    const utc = now.getTime() + now.getTimezoneOffset() * 60000;
    return new Date(utc + 7 * 3600000);
  }

  function updateClock() {
    const wib = getWIBNow();
    const h = wib.getHours(), m = wib.getMinutes(), s = wib.getSeconds();
    document.getElementById('hh').textContent = pad(h);
    document.getElementById('mm').textContent = pad(m);
    document.getElementById('ss').textContent = pad(s);

    document.getElementById('dayName').textContent = DAYS_ID[wib.getDay()];
    document.getElementById('dateStr').textContent =
      `${pad(wib.getDate())} ${MONTHS_ID[wib.getMonth()]} ${wib.getFullYear()}`;

    // Hitung posisi dalam siklus 60 menit berdasarkan menit+detik
    const totalSec = (m * 60 + s); // 0–3599
    const posInCycle = totalSec % CYCLE; // 0–3599

    // Menit genap 0–29: stopwatch ON (posInCycle 0–1799)
    // Menit genap 30–59: stopwatch OFF (posInCycle 1800–3599)
    const shouldRun = posInCycle < SW_DURATION;

    if (shouldRun && !swRunning) startSW(wib);
    if (!shouldRun && swRunning) stopSW(wib);

    // Update next countdown
    if (!shouldRun) {
      const secsUntilNext = CYCLE - posInCycle; // detik sampai menit berikutnya yang genap
      const nm = Math.floor(secsUntilNext / 60);
      const ns = secsUntilNext % 60;
      document.getElementById('nextCountdown').textContent = `${pad(nm)}:${pad(ns)}`;
      const pct = ((CYCLE - posInCycle) / (CYCLE - SW_DURATION)) * 100;
      document.getElementById('nextProgress').style.width = Math.min(100, 100 - (secsUntilNext / (CYCLE - SW_DURATION)) * 100) + '%';
    } else {
      document.getElementById('nextCountdown').textContent = `AKTIF`;
      document.getElementById('nextProgress').style.width = '100%';
    }
  }

  function startSW(wib) {
    swRunning = true;
    // Hitung elapsed berdasarkan posisi aktual
    const m = wib.getMinutes(), s = wib.getSeconds();
    const posInCycle = (m * 60 + s) % CYCLE;
    swElapsed = posInCycle; // berapa detik sudah berjalan dalam sesi ON ini

    document.getElementById('swPanel').className = 'sw-panel active';
    document.getElementById('swStatusText').textContent = 'RUNNING';
    addLog(wib, 'start', 'Stopwatch dimulai');
  }

  function stopSW(wib) {
    swRunning = false;
    swElapsed = 0;
    document.getElementById('swPanel').className = 'sw-panel idle';
    document.getElementById('swStatusText').textContent = 'STANDBY';
    document.getElementById('swDisplay').textContent = '00:00';
    document.getElementById('swProgressFill').style.width = '0%';
    document.getElementById('swDurLabel').textContent = '0 / 30 menit';
    addLog(wib, 'stop', 'Stopwatch dihentikan');
  }

  function updateSW() {
    if (!swRunning) return;
    const wib = getWIBNow();
    const m = wib.getMinutes(), s = wib.getSeconds();
    const posInCycle = (m * 60 + s) % CYCLE;
    swElapsed = posInCycle < SW_DURATION ? posInCycle : SW_DURATION;

    const mm = Math.floor(swElapsed / 60);
    const ss = swElapsed % 60;
    document.getElementById('swDisplay').textContent = `${pad(mm)}:${pad(ss)}`;

    const pct = (swElapsed / SW_DURATION) * 100;
    document.getElementById('swProgressFill').style.width = pct + '%';
    document.getElementById('swDurLabel').textContent = `${mm} / 30 menit`;
  }

  function addLog(wib, type, msg) {
    const timeStr = `${pad(wib.getHours())}:${pad(wib.getMinutes())}:${pad(wib.getSeconds())}`;
    logs.unshift({ time: timeStr, type, msg });
    if (logs.length > 8) logs.pop();
    renderLog();
  }

  function renderLog() {
    const list = document.getElementById('logList');
    const empty = document.getElementById('logEmpty');
    if (logs.length === 0) {
      if (empty) empty.style.display = '';
      return;
    }
    if (empty) empty.style.display = 'none';
    list.innerHTML = logs.map(l => `
      <li class="log-item ${l.type}">
        <span class="log-time">${l.time}</span>
        <span class="log-event">${l.msg}</span>
      </li>
    `).join('');
  }

  // Tick setiap detik
  function tick() {
    updateClock();
    updateSW();
  }

  tick();
  setInterval(tick, 1000);
</script>
</body>
</html>
